generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum UserType {
  CANDIDATE
  RECRUITER
}

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  DELETED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum JobSource {
  PARSED      // scraped / parsed from external sources
  HR_ADDED    // added manually by internal HR/admin/moderator
  COMPANY_ADDED // added by a company account
  SELF_POSTED // added without a company (individual recruiter)
  JOB_ECO     // imported from job-eco public API
}

enum JobStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WorkType {
  REMOTE
  HYBRID
  OFFICE
}

enum ExperienceLevel {
  INTERN
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum Currency {
  USD
  EUR
  GBP
  RUB
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

// ---------- Core auth/account ----------

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  emailVerified  DateTime?
  passwordHash   String?
  name           String?

  type           UserType   @default(CANDIDATE)
  role           UserRole   @default(USER)
  status         UserStatus @default(ACTIVE)

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  lastLoginAt    DateTime?

  // Relations
  sessions       Session[]
  apiTokens      ApiToken[]
  subscription   Subscription?

  companiesOwned Company[]  @relation("CompanyOwner")
  jobsCreated    Job[]      @relation("JobCreator")
  applications   Application[]

  blogPosts      BlogPost[] @relation("BlogAuthor")

  @@index([type])
  @@index([role])
  @@index([status])
}

// Refresh-token based sessions (for web auth later)
model Session {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshTokenHash String
  userAgent        String?
  ip               String?

  createdAt        DateTime @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  @@index([userId])
  @@index([expiresAt])
}

// Long-lived API tokens (for integrations later)
model ApiToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  tokenHash   String   @unique
  lastUsedAt  DateTime?

  createdAt   DateTime @default(now())
  expiresAt   DateTime?
  revokedAt   DateTime?

  @@index([userId])
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)

  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)

  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([plan])
  @@index([status])
}

// ---------- Companies / Jobs / Applications ----------

model Company {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  website     String?
  description String?
  logoUrl     String?

  verified    Boolean  @default(false)

  // Enriched data from job-eco / other sources
  industry     String?
  size         String?
  founded      String?
  headquarters String?
  summary      String?
  socials      Json?
  domains      String[] @default([])

  ownerUserId String?
  ownerUser   User?    @relation("CompanyOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  jobs        Job[]

  @@index([ownerUserId])
  @@index([verified])
  @@index([name])
}

model Job {
  id            String          @id @default(cuid())
  slug          String          @unique

  title         String
  description   String          @db.Text
  summary       String?         @db.Text
  requirements  String?         @db.Text
  responsibilities String?      @db.Text
  conditions    String?         @db.Text
  rawText       String?         @db.Text

  // Salary: keep flexible; later can normalize better
  salaryText    String?
  salaryMin     Int?
  salaryMax     Int?
  currency      Currency?

  locationText  String
  workType      WorkType        @default(REMOTE)
  experience    ExperienceLevel @default(MID)

  tags          String[]        @default([])
  skills        String[]        @default([])
  stack         String[]        @default([])
  domains       String[]        @default([])

  // Flags managed by admin/HR
  featured      Boolean         @default(false)
  verified      Boolean         @default(false)

  // Raw/external fields (mirror of job-eco payload)
  role             String?
  seniorityRaw     String?
  employmentType   String?
  englishLevel     String?
  experienceYears  Int?
  countryCity      String?
  locationType     String?
  sourceChannel    String?
  recruiter        String?
  riskLabel        String?
  aiScore          Float?
  scoring          Json?
  contacts         Json?

  source        JobSource       @default(PARSED)
  sourceUrl     String?
  externalId    Int?            // id in source system (e.g. job-eco vacancy id)
  recruiterContact String?      // Telegram username, email, or phone

  status        JobStatus       @default(PUBLISHED)

  postedAt      DateTime?       // external publish date if parsed
  lastSeenAt    DateTime?       // last time we confirmed this job is still listed upstream

  // Engagement (denormalized applyCount updated on new Application; viewCount on unique daily views)
  viewCount     Int             @default(0)
  applyCount    Int             @default(0)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  companyId     String?
  company       Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdByUserId String?
  createdByUser   User?         @relation("JobCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  applications  Application[]
  presences     JobPresence[]
  uniqueDailyViews   JobUniqueDailyView[]
  uniqueDailyApplies JobApplyClick[]

  @@unique([source, externalId])
  @@index([companyId])
  @@index([status])
  @@index([source])
  @@index([featured])
  @@index([verified])
  @@index([workType])
  @@index([experience])
  @@index([postedAt])
  @@index([lastSeenAt])
  @@index([aiScore])
  @@index([externalId])
}

model Application {
  id         String            @id @default(cuid())
  userId     String
  jobId      String

  status     ApplicationStatus @default(APPLIED)
  note       String?

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  job        Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([jobId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ---------- Site-wide toggles (singleton row id = "default") ----------
model SiteSettings {
  id String @id @default("default")

  /** When false, public job cards & job page hide view / apply counters (admins still see all). */
  showPublicJobViewCounts Boolean @default(true)
  /** When false, hide “watching now” on the job page for visitors. */
  showPublicWatchingCount Boolean @default(true)

  updatedAt DateTime @updatedAt
}

// ---------- Job page: unique view per visitor per calendar day ----------
model JobUniqueDailyView {
  jobId     String
  day       String // "YYYY-MM-DD" UTC
  viewerKey String

  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@id([jobId, day, viewerKey])
  @@index([jobId])
}

// ---------- Job page: unique apply-button click per visitor per calendar day ----------
model JobApplyClick {
  jobId     String
  day       String // "YYYY-MM-DD" UTC
  viewerKey String

  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@id([jobId, day, viewerKey])
  @@index([jobId])
}

// ---------- Job page: who is on the vacancy right now (heartbeat) ----------
model JobPresence {
  id         String   @id @default(cuid())
  jobId      String
  viewerKey  String
  lastPingAt DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, viewerKey])
  @@index([jobId, lastPingAt])
}

// ---------- Analytics / Page views ----------

model DailyPageView {
  id    String @id @default(cuid())
  path  String
  day   String // "YYYY-MM-DD"
  views Int    @default(0)

  @@unique([path, day])
  @@index([day])
}

// Unique anonymous visitor (identified by a cookie that we set on first page view).
// firstSeen is the signal we use for "new visitors" charts.
model Visitor {
  id            String   @id // cuid we put into the cookie
  firstSeen     DateTime @default(now())
  lastSeen      DateTime @default(now())
  pageViews     Int      @default(0)
  firstPath     String?  // first page they landed on
  firstReferrer String?  // where they came from (document.referrer on first visit)
  userAgent     String?
  ip            String?  // last known IP (kept for admin-only activity view)
  country       String?  // ISO-2 country code from edge/CDN headers, when available
  userId        String?  // set when an authenticated user is detected (not FK — keeps this lean)

  views         PageView[]

  @@index([firstSeen])
  @@index([lastSeen])
  @@index([userId])
}

// Individual page view event — lets us show exactly what a visitor looked at & when.
model PageView {
  id        String   @id @default(cuid())
  visitorId String
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  path      String
  referrer  String?
  createdAt DateTime @default(now())

  @@index([visitorId])
  @@index([createdAt])
  @@index([path])
}

// ---------- Email verification ----------

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// ---------- Blog ----------

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  excerpt     String?
  content     String
  coverImage  String?

  published   Boolean  @default(false)
  publishedAt DateTime?

  authorUserId String?
  author       User?    @relation("BlogAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([publishedAt])
  @@index([authorUserId])
}

